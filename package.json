{
  "name": "fraidycat",
  "description": "Follow blogs, wikis, YouTube, Twitter, Reddit, Instagram and the like... from a distance.",
  "homepage": "https://fraidyc.at/",
  "productName": "Fraidycat",
  "author": {
    "name": "Kicks Condor",
    "email": "kicks@kickscondor.com"
  },
  "repository": {
    "url": "https://github.com/kickscondor/fraidycat"
  },
  "version": "2.0.0",
  "scripts": {
    "dev": "cross-env STORAGE=mock parcel serve src/dev.html --target frontend --port 4321",
    "test": "ava",
    "webext": "fsbin emptyDir build/webext && cross-env STORAGE=webext parcel build --target webext --config @parcel/config-webextension --no-cache --no-source-maps --no-content-hash",
    "webext:lint": "web-ext lint --source-dir ./build/webext/"
  },
  "targets": {
    "frontend": {
      "distDir": "build/frontend",
      "scopeHoist": false,
      "optimize": false,
      "engines": {
        "browsers": "chrome >= 116"
      }
    },
    "webext": {
      "distDir": "build/webext",
      "source": "src/manifest.json",
      "scopeHoist": false,
      "engines": {
        "browsers": "chrome >= 116"
      }
    }
  },
  "browserslist": "chrome >= 116",
  "dependencies": {
    "@xmldom/xmldom": "^0.7.5",
    "domify": "^1.4.1",
    "fraidyscrape": "^1.0.16",
    "json-date-parser": "^1.0.1",
    "normalize-url": "^7.0.2",
    "opml-generator": "^1.1.1",
    "regenerator-runtime": "^0.13.9",
    "twemoji": "^13.1.0",
    "xpath": "^0.0.32"
  },
  "devDependencies": {
    "@babel/core": "^7.15.5",
    "@babel/preset-env": "^7.15.6",
    "@kickscondor/emoji-button": "^2.1.4",
    "@kickscondor/router": "^0.7.3",
    "@kickscondor/umbrellajs": "^3.1.2",
    "@parcel/config-webextension": "2.13.3",
    "@parcel/transformer-image": "2.13.3",
    "@parcel/transformer-sass": "2.13.3",
    "ava": "^3.15.0",
    "cross-env": "^7.0.3",
    "ent": "^2.2.0",
    "events": "^3.3.0",
    "fast-json-patch": "^3.1.0",
    "fsbin": "^1.0.11",
    "hyperapp": "^1.2.10",
    "parcel": "2.13.3",
    "process": "^0.11.10",
    "sass": "^1.39.2",
    "stream-browserify": "^3.0.0",
    "svgo": "^3.3.3",
    "url": "^0.11.4",
    "web-ext": "^4.3.0",
    "webextension-polyfill": "^0.12.0"
  }
}
