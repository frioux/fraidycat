{
  "manifest_version": 3,
  "name": "Scaredycat",
  "short_name": "Scaredycat",
  "key": "hecfkgekabkkhiidlinmifelhdooeool",
  "version": "1.2.0",
  "minimum_chrome_version": "116",
  "description": "Follow from afar.",
  "homepage_url": "https://github.com/frioux/fraidycat",
  "icons": {
    "32": "images/flatcat-32.png",
    "48": "images/flatcat-48.png",
    "64": "images/flatcat-64.png",
    "128": "images/flatcat-128.png"
  },

  "options_ui": {
    "page": "settings.html"
  },
  "content_scripts": [{
    "matches": ["*://*/*"],
    "js": ["js/webext/content-script.js"],
    "all_frames": true
  }],
  "web_accessible_resources": [{
    "resources": ["index.html", "popup.html", "offscreen.html", "fonts/*", "images/*"],
    "matches": ["<all_urls>"]
  }],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "scaredycat@frew.co",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "action": {
    "default_title": "Scaredycat",
    "default_icon": {
      "16": "images/flatcat-16.png",
      "32": "images/flatcat-32.png",
      "64": "images/flatcat-64.png"
    }
  },
  "permissions": [
    "storage",
    "tabs",
    "unlimitedStorage",
    "webRequest",
    "offscreen",
    "alarms",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
